{
  "manifest_version": 3,
  "name": "RepoMind — AI GitHub Repo Analyzer",
  "version": "0.1.0",
  "description": "Understand any GitHub repository in seconds. One-click AI analysis with architecture maps, dependency graphs, onboarding guides, and conversational AI.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "RepoMind — Scan this repo"
  },
  "side_panel": {
    "default_path": "panel/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/detector.ts-CNVb383z.js"
      ],
      "matches": [
        "https://github.com/*"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "resources": [
        "assets/detector.ts-CNVb383z.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
