generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum RepoStatus {
  QUEUED
  CLONING
  PARSING
  ANALYZING
  COMPLETE
  FAILED
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  TIMEOUT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum PaymentType {
  SUBSCRIPTION
  ONE_TIME
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum FeedbackType {
  BUG
  FEATURE
  GENERAL
}

enum FeedbackStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  name             String?
  image            String?
  passwordHash     String?
  emailVerified    DateTime?
  githubId         String?        @unique
  githubUsername   String?        @unique
  plan             Plan           @default(FREE)
  creditsRemaining Int            @default(3)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  accounts     Account[]
  sessions     Session[]
  repos        Repo[]
  subscription Subscription?
  payments     Payment[]
  feedback     Feedback[]
}

model Repo {
  id              String     @id @default(uuid())
  userId          String
  githubUrl       String
  owner           String
  name            String
  branch          String     @default("main")
  defaultLanguage String?
  totalFiles      Int        @default(0)
  totalLines      Int        @default(0)
  status          RepoStatus @default(QUEUED)
  errorMessage    String?    @db.Text
  analyzedAt      DateTime?
  expiresAt       DateTime?
  isPublicResult  Boolean    @default(false)
  shareSlug       String?    @unique
  createdAt       DateTime   @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisResult AnalysisResult?
  job            Job?

  @@unique([githubUrl, branch])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([shareSlug])
}

model AnalysisResult {
  id              String   @id @default(uuid())
  repoId          String   @unique
  summary         String   @db.Text
  architecture    Json
  fileTree        Json
  dependencyGraph Json
  entryPoints     Json
  startGuide      String   @db.Text
  fileSummaries   Json
  techStack       Json
  createdAt       DateTime @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
}

model Job {
  id          String    @id @default(uuid())
  repoId      String    @unique
  status      JobStatus @default(QUEUED)
  progress    Int       @default(0)
  currentStep String?
  startedAt   DateTime?
  completedAt DateTime?
  workerId    String?
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  errorLog    String?   @db.Text
  createdAt   DateTime  @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String             @unique
  plan               Plan
  status             SubscriptionStatus @default(ACTIVE)
  razorpaySubId      String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String        @id @default(uuid())
  userId            String
  amount            Int
  currency          String        @default("INR")
  type              PaymentType
  status            PaymentStatus @default(PENDING)
  razorpayPaymentId String?
  razorpayOrderId   String?
  metadata          Json?
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Feedback {
  id        String         @id @default(uuid())
  userId    String
  repoId    String?
  type      FeedbackType   @default(GENERAL)
  message   String         @db.Text
  status    FeedbackStatus @default(OPEN)
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
}
